.filter {
  display: grid;
  padding: 8rpx;
  margin-bottom: 22rpx;
  overflow: hidden;
}

.filter.cols-2 {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.filter.cols-3 {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.filter.cols-4 {
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.filter-item {
  min-height: 68rpx;
  border-radius: 8rpx;
  color: #66726e;
  text-align: center;
  line-height: 68rpx;
  font-size: 24rpx;
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.filter-item.active {
  color: #ffffff;
  background: #1f5f54;
}

.approval-card {
  padding: 26rpx;
  overflow: hidden;
}

.approval-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  min-width: 0;
}

.approval-head > view:first-child {
  min-width: 0;
}

.type {
  color: #1f5f54;
  font-size: 24rpx;
  font-weight: 800;
}

.title {
  margin-top: 8rpx;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.35;
  word-break: break-word;
}

.detail {
  margin-top: 18rpx;
  color: #46534f;
  font-size: 27rpx;
  line-height: 1.55;
}

.instrument-detail-link {
  display: inline-flex;
  align-items: center;
  height: 48rpx;
  margin-top: 14rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: #1f5f54;
  background: #edf7f4;
  font-size: 23rpx;
  font-weight: 800;
}

.change-box {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 10rpx;
  background: #f4f8f7;
}

.change-line {
  color: #26332f;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.55;
  word-break: break-word;
}

.change-line + .change-line {
  margin-top: 8rpx;
}

.flow-line {
  margin-top: 14rpx;
  padding: 14rpx 16rpx;
  border-radius: 8rpx;
  color: #1f5f54;
  background: #edf7f4;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.45;
  word-break: break-word;
}

.muted-flow {
  color: #6b7773;
  background: #f4f7f6;
  font-weight: 600;
}

.meta {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 18rpx;
  color: #6b7773;
  font-size: 24rpx;
  flex-wrap: wrap;
}

.actions {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 14rpx;
  margin-top: 24rpx;
  width: 100%;
  overflow: hidden;
}

.actions .primary-button,
.actions .ghost-button {
  width: 100%;
  min-width: 0;
  height: 76rpx;
  padding: 0;
  font-size: 27rpx;
}

.detail-mask {
  position: fixed;
  inset: 0;
  z-index: 50;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  background: rgba(0, 0, 0, 0.36);
}

.detail-panel {
  width: 100%;
  max-height: 78vh;
  padding: 26rpx;
  border-radius: 22rpx 22rpx 0 0;
  background: #ffffff;
  overflow-y: auto;
}

.detail-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.detail-title {
  color: #17211e;
  font-size: 31rpx;
  font-weight: 900;
}

.detail-close {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  color: #1f5f54;
  background: #edf7f4;
  font-size: 34rpx;
  font-weight: 800;
}

.detail-line {
  margin-top: 12rpx;
  color: #52615d;
  font-size: 25rpx;
  line-height: 1.5;
}

.detail-subtitle {
  margin-top: 22rpx;
  color: #17211e;
  font-size: 26rpx;
  font-weight: 900;
}

.detail-equipment {
  margin-top: 10rpx;
  padding: 14rpx 16rpx;
  border-radius: 8rpx;
  color: #26332f;
  background: #f4f8f7;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.45;
}
