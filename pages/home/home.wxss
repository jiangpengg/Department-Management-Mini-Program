.hero {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  min-height: 220rpx;
  padding: 34rpx;
  border-radius: 16rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #1f5f54 0%, #287466 62%, #8d6a33 100%);
}

.hero-kicker {
  margin-bottom: 14rpx;
  font-size: 26rpx;
  opacity: 0.86;
}

.hero-title {
  font-size: 42rpx;
  font-weight: 800;
}

.hero-side {
  display: grid;
  justify-items: end;
  gap: 10rpx;
}

.hero-date {
  padding: 12rpx 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.42);
  border-radius: 999rpx;
  font-size: 24rpx;
}

.hero-weather {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: rgba(255, 255, 255, 0.92);
  background: rgba(255, 255, 255, 0.13);
  font-size: 22rpx;
  font-weight: 700;
}

.metrics {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
  margin-top: 20rpx;
}

.metric {
  padding: 22rpx 10rpx;
  text-align: center;
}

.metric-value {
  color: #1f5f54;
  font-size: 38rpx;
  font-weight: 800;
}

.metric-value text {
  margin-left: 2rpx;
  font-size: 20rpx;
}

.metric-label {
  margin-top: 8rpx;
  color: #66726e;
  font-size: 23rpx;
}

.metric:nth-child(n + 5) {
  grid-column: span 1;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.quick-card {
  min-height: 154rpx;
  padding: 22rpx;
}

.quick-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  margin-bottom: 18rpx;
  border-radius: 10rpx;
  color: #ffffff;
  background: #1f5f54;
  font-size: 28rpx;
  font-weight: 800;
}

.quick-name {
  font-size: 28rpx;
  font-weight: 800;
}

.application {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 24rpx;
}

.application-main {
  min-width: 0;
}

.application-type {
  color: #1f5f54;
  font-size: 24rpx;
  font-weight: 700;
}

.application-title {
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.application-meta {
  margin-top: 10rpx;
  color: #6b7773;
  font-size: 24rpx;
}

.project-alert {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx;
  border-left: 8rpx solid #c45a4a;
}

.project-alert-title {
  font-size: 30rpx;
  font-weight: 800;
}

.project-alert-meta {
  margin-top: 12rpx;
  color: #6b7773;
  font-size: 25rpx;
}

.project-alert-progress {
  color: #c45a4a;
  font-size: 42rpx;
  font-weight: 900;
}
