<view class="page">
  <view class="hero">
    <view>
      <view class="hero-kicker">{{instituteName}}</view>
      <view class="hero-title">所事务工作台</view>
    </view>
    <view class="hero-side">
      <view class="hero-date">{{todayText}}</view>
      <view class="hero-weather">{{weather}}</view>
    </view>
  </view>

  <view class="metrics">
    <view class="metric card" wx:for="{{metrics}}" wx:key="label">
      <view class="metric-value">{{item.value}}<text>{{item.unit}}</text></view>
      <view class="metric-label">{{item.label}}</view>
    </view>
  </view>

  <view class="section-title">
    <text>快捷申请</text>
  </view>
  <view class="quick-grid">
    <view class="quick-card card" wx:for="{{applicationTypes}}" wx:key="key" bindtap="goApply" data-type="{{item.key}}">
      <view class="quick-icon">{{item.icon}}</view>
      <view class="quick-name">{{item.name}}</view>
    </view>
  </view>

  <view class="section-title">
    <text>本周现场工作</text>
  </view>
  <view class="list">
    <view class="application card" wx:for="{{onsiteWorks}}" wx:key="id">
      <view class="application-main">
        <view class="application-type">{{item.department}}</view>
        <view class="application-title">{{item.title}}</view>
        <view class="application-meta">{{item.owner}} · {{item.date}}</view>
      </view>
      <status-pill text="{{item.statusText}}" tone="{{item.statusTone}}" />
    </view>
    <view class="empty" wx:if="{{onsiteWorks.length === 0}}">本周暂无现场工作</view>
  </view>

  <view class="section-title">
    <text>应急支撑情况</text>
  </view>
  <view class="list">
    <view class="application card" wx:for="{{emergencyWorks}}" wx:key="id">
      <view class="application-main">
        <view class="application-type">{{item.department}}</view>
        <view class="application-title">{{item.title}}</view>
        <view class="application-meta">{{item.owner}} · 截止 {{item.deadline}}</view>
      </view>
      <status-pill text="{{item.statusText}}" tone="{{item.statusTone}}" />
    </view>
    <view class="empty" wx:if="{{emergencyWorks.length === 0}}">暂无未闭环应急工作</view>
  </view>

  <view class="section-title">
    <text>项目推进情况</text>
  </view>
  <view class="list">
    <view class="project-alert card" wx:for="{{projectWorks}}" wx:key="id">
      <view>
        <view class="project-alert-title">{{item.name}}</view>
        <view class="project-alert-meta">{{item.stage}} · {{item.nextNode}}</view>
      </view>
      <view class="project-alert-progress">{{item.progress}}%</view>
    </view>
  </view>
</view>
