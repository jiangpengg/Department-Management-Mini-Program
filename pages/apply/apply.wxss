.type-tabs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  padding: 8rpx;
}

.type-tab {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 76rpx;
  border-radius: 8rpx;
  color: #66726e;
  font-size: 26rpx;
  font-weight: 700;
}

.type-tab.active {
  color: #ffffff;
  background: #1f5f54;
}

.form {
  margin-top: 22rpx;
  padding: 30rpx;
}

.form-title {
  font-size: 36rpx;
  font-weight: 900;
}

.form-subtitle {
  margin-top: 10rpx;
  color: #6b7773;
  font-size: 26rpx;
}

.field {
  margin-top: 28rpx;
}

.label {
  margin-bottom: 14rpx;
  color: #33423e;
  font-size: 26rpx;
  font-weight: 700;
}

input,
textarea,
.picker-value {
  width: 100%;
  border: 1rpx solid #d7e1de;
  border-radius: 10rpx;
  background: #fbfcfc;
  font-size: 28rpx;
}

input,
.picker-value {
  height: 82rpx;
  padding: 0 22rpx;
  line-height: 82rpx;
}

textarea {
  min-height: 170rpx;
  padding: 22rpx;
  line-height: 1.55;
}

.check-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-height: 72rpx;
  color: #24332f;
  font-size: 28rpx;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #9dafaa;
  border-radius: 8rpx;
}

.checkbox.checked {
  border-color: #1f5f54;
  background: #1f5f54;
}

.primary-button {
  margin-top: 34rpx;
}

.slot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
}

.slot-room {
  font-size: 29rpx;
  font-weight: 800;
}

.slot-time {
  margin-top: 8rpx;
  color: #6b7773;
  font-size: 24rpx;
}

.slot-status {
  min-width: 104rpx;
  height: 44rpx;
  border-radius: 999rpx;
  text-align: center;
  line-height: 44rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.slot-status.available {
  color: #126a45;
  background: #dff5e9;
}

.slot-status.busy {
  color: #a02727;
  background: #ffe2e0;
}
