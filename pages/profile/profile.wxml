<view class="page">
  <view class="profile card">
    <view class="avatar">{{avatarText}}</view>
    <view>
      <view class="name">{{user.name}}</view>
      <view class="dept">{{user.department}} · {{user.role}}</view>
    </view>
  </view>

  <view class="section-title">
    <text>管理配置</text>
  </view>
  <view class="menu card">
    <view class="menu-item">
      <text>人员与权限</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item">
      <text>审批流程配置</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item">
      <text>会议室与印章台账</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item">
      <text>订阅消息模板</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="section-title">
    <text>建设路线</text>
  </view>
  <view class="roadmap card">
    <view class="roadmap-item">第一阶段：申请、审批、任务、项目台账</view>
    <view class="roadmap-item">第二阶段：云数据库、云函数、附件上传</view>
    <view class="roadmap-item">第三阶段：订阅消息、腾讯会议接口、统计报表</view>
  </view>
</view>
