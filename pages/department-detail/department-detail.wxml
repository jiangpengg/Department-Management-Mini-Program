<view class="page">
  <view class="admin-head card">
    <view>
      <view class="admin-title">{{department.name}}</view>
      <view class="admin-subtitle">查看科室人员，从组织内搜索添加人员</view>
    </view>
  </view>

  <view class="section-title">
    <text>添加人员</text>
  </view>
  <view class="search-card card">
    <input value="{{searchKeyword}}" bindinput="onSearch" placeholder="搜索组织内人员姓名" />
    <view class="search-result" wx:for="{{searchResults}}" wx:key="id">
      <view>
        <view class="user-name">{{item.name}}</view>
        <view class="user-meta">{{item.department}} · {{item.role}}</view>
      </view>
      <button class="text-button" data-id="{{item.id}}" bindtap="addExistingMember">加入</button>
    </view>
  </view>

  <view class="section-title">
    <text>科室人员</text>
  </view>
  <view class="list">
    <view class="user-card card" wx:for="{{members}}" wx:key="id">
      <view class="user-main">
        <view class="user-name">{{item.name}}</view>
        <view class="user-meta">{{item.role}} · {{item.authorized ? '已授权' : '禁用'}}</view>
      </view>
      <button class="danger-link" data-id="{{item.id}}" bindtap="removeMember">移出</button>
    </view>
  </view>
</view>
