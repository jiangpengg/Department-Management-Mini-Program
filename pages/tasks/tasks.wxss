.task-toolbar {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 14rpx;
  min-height: 72rpx;
  margin-bottom: 22rpx;
}

.task-toolbar-title {
  flex: 1;
  min-width: 0;
  padding-right: 12rpx;
}

.page-title {
  position: relative;
  display: inline-flex;
  align-items: center;
  padding-left: 16rpx;
  color: #17211e;
  font-size: 39rpx;
  font-weight: 900;
  white-space: nowrap;
  letter-spacing: 0;
}

.page-title::before {
  content: "";
  position: absolute;
  left: 0;
  width: 6rpx;
  height: 34rpx;
  border-radius: 999rpx;
  background: #1f5f54;
}

.page-subtitle {
  margin-top: 8rpx;
  color: #6b7773;
  font-size: 26rpx;
  line-height: 1.35;
}

.add-button {
  flex: 0 0 104rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 104rpx;
  height: 50rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: #1f5f54;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1;
  box-shadow: 0 8rpx 18rpx rgba(31, 95, 84, 0.16);
  white-space: nowrap;
}

.toolbar-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
  flex-shrink: 0;
  width: 210rpx;
}

.toolbar-config-button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 86rpx;
  width: 86rpx;
  height: 50rpx;
  margin: 0;
  padding: 0 16rpx;
  border: 1rpx solid #dbe6e3;
  border-radius: 999rpx;
  color: #1f5f54;
  background: #ffffff;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 50rpx;
  box-shadow: none;
  white-space: nowrap;
}

.work-summary {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.summary-card {
  padding: 18rpx 8rpx;
  text-align: center;
}

.summary-card.active {
  border-color: #1f5f54;
  background: #edf7f4;
}

.summary-value {
  color: #1f5f54;
  font-size: 34rpx;
  font-weight: 900;
}

.summary-value text {
  margin-left: 2rpx;
  font-size: 18rpx;
}

.summary-name {
  margin-top: 6rpx;
  color: #66726e;
  font-size: 22rpx;
  font-weight: 700;
}

.category-tabs {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
  margin-bottom: 20rpx;
  padding: 8rpx;
  border: 1rpx solid #dbe4e1;
  border-radius: 12rpx;
  background: #ffffff;
}

.category-tab {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 64rpx;
  border-radius: 8rpx;
  color: #66726e;
  font-size: 24rpx;
  font-weight: 800;
}

.category-tab.active {
  color: #ffffff;
  background: #1f5f54;
}

.onsite-filters {
  margin-bottom: 18rpx;
}

.filter-row {
  display: flex;
  gap: 10rpx;
}

.compact-filter-row {
  display: grid;
  grid-template-columns: 0.7fr 0.7fr 1.15fr;
  gap: 10rpx;
}

.filter-chip {
  min-width: 0;
  height: 58rpx;
  border: 1rpx solid #d7e1de;
  border-radius: 8rpx;
  color: #52615d;
  background: #ffffff;
  text-align: center;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 58rpx;
}

.owner-filter-chip {
  width: 100%;
}

.time-filter-picker {
  width: 100%;
}

.time-filter-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  width: 100%;
  color: #1f5f54;
  background: #ffffff;
}

.time-filter-arrow {
  display: inline-flex;
  align-items: center;
  height: 58rpx;
  color: #1f5f54;
  font-size: 22rpx;
  line-height: 58rpx;
  transform: translateY(-2rpx);
}

.filter-chip.active {
  border-color: #1f5f54;
  color: #ffffff;
  background: #1f5f54;
}

.task-card {
  padding: 26rpx;
  overflow: hidden;
}

.task-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.task-title {
  flex: 1;
  min-width: 0;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.35;
}

.task-meta {
  display: grid;
  grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr) minmax(0, 0.9fr);
  align-items: center;
  column-gap: 10rpx;
  margin-top: 18rpx;
  color: #6b7773;
  font-size: 24rpx;
  min-width: 0;
  line-height: 36rpx;
}

.meta-item {
  min-width: 0;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.risk-meta {
  text-align: center;
}

.time-meta {
  text-align: right;
}

.risk-number {
  font-weight: 900;
}

.risk-number.red {
  color: #c0392b;
}

.risk-number.amber {
  color: #b7791f;
}

.task-detail {
  display: grid;
  gap: 8rpx;
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 8rpx;
  color: #40504b;
  background: #f4f7f6;
  font-size: 24rpx;
  line-height: 1.4;
}

.people-line {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.progress {
  height: 16rpx;
  margin-top: 24rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #e7eeeb;
}

.progress-bar {
  height: 100%;
  border-radius: 999rpx;
  background: #1f5f54;
}

.task-footer {
  display: block;
  margin-top: 22rpx;
}

.task-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  width: 100%;
}

.priority {
  color: #40504b;
  font-size: 25rpx;
}

.mini-button {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  min-width: 0;
  width: 100%;
  height: 56rpx;
  border: 1rpx solid #b9c9c4;
  border-radius: 999rpx;
  color: #1f5f54;
  background: #ffffff;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1;
}

.work-mask {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  top: 0;
  z-index: 130;
  display: flex;
  align-items: flex-end;
  background: rgba(0, 0, 0, 0.35);
}

.work-panel {
  width: 100%;
  height: 92vh;
  max-height: 92vh;
  border-radius: 18rpx 18rpx 0 0;
  background: #ffffff;
  overflow: hidden;
}

.work-panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 92rpx;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #edf2f0;
}

.panel-title {
  flex: 1;
  min-width: 0;
  color: #17211e;
  font-size: 30rpx;
  font-weight: 900;
  text-align: center;
  white-space: nowrap;
}

.panel-action {
  flex: 0 0 92rpx;
  min-width: 92rpx;
  height: 56rpx;
  color: #65736f;
  font-size: 26rpx;
  font-weight: 800;
}

.panel-action.primary {
  color: #1f5f54;
}

.work-form {
  max-height: calc(92vh - 92rpx);
  overflow-y: auto;
  padding: 18rpx 24rpx calc(150rpx + env(safe-area-inset-bottom));
}

.field {
  margin-bottom: 18rpx;
}

.label {
  margin-bottom: 8rpx;
  color: #33423e;
  font-size: 25rpx;
  font-weight: 800;
}

.work-form input,
.work-form textarea,
.picker-value {
  width: 100%;
  border: 1rpx solid #d7e1de;
  border-radius: 8rpx;
  background: #fbfcfc;
  color: #17211e;
  font-size: 27rpx;
}

.work-form input,
.picker-value {
  height: 70rpx;
  padding: 0 20rpx;
  line-height: 70rpx;
}

.date-range-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 42rpx minmax(0, 1fr);
  align-items: center;
  gap: 10rpx;
}

.picker-value.compact {
  padding: 0 12rpx;
  text-align: center;
  font-size: 25rpx;
}

.date-range-separator {
  color: #66726e;
  text-align: center;
  font-size: 24rpx;
  font-weight: 800;
}

.risk-row {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 10rpx;
}

.risk-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 62rpx;
  border: 1rpx solid #d7e1de;
  border-radius: 8rpx;
  color: #40504b;
  background: #fbfcfc;
  font-size: 26rpx;
  font-weight: 800;
}

.risk-chip.active {
  border-color: #1f5f54;
  color: #ffffff;
  background: #1f5f54;
}

.select-project-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 70rpx;
  padding: 0 20rpx;
  border: 1rpx solid #d7e1de;
  border-radius: 8rpx;
  color: #17211e;
  background: #fbfcfc;
  font-size: 27rpx;
  font-weight: 800;
}

.select-arrow {
  color: #1f5f54;
  font-size: 24rpx;
}

.suggestion-list {
  margin-top: 10rpx;
  border: 1rpx solid #d7e1de;
  border-radius: 8rpx;
  background: #ffffff;
  overflow: hidden;
}

.suggestion-item {
  min-height: 68rpx;
  padding: 0 20rpx;
  border-bottom: 1rpx solid #edf2f0;
  color: #17211e;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 68rpx;
}

.suggestion-item:last-child {
  border-bottom: 0;
}

.select-people-box {
  min-height: 70rpx;
  padding: 16rpx 18rpx;
  border: 1rpx solid #d7e1de;
  border-radius: 8rpx;
  color: #17211e;
  background: #fbfcfc;
  font-size: 26rpx;
  line-height: 1.4;
}

.selected-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.selected-tag {
  display: inline-flex;
  align-items: center;
  max-width: 100%;
  min-height: 52rpx;
  padding: 0 10rpx 0 16rpx;
  border-radius: 999rpx;
  color: #1f5f54;
  background: #edf7f4;
  font-size: 24rpx;
  font-weight: 800;
}

.tag-remove {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38rpx;
  height: 38rpx;
  margin-left: 8rpx;
  border-radius: 50%;
  color: #ffffff;
  background: #1f5f54;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 1;
}

.delete-task-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  margin-top: 8rpx;
  border: 1rpx solid #e0b4b4;
  border-radius: 8rpx;
  color: #b42318;
  background: #fff7f7;
  font-size: 27rpx;
  font-weight: 900;
}

.placeholder {
  color: #8a9692;
}

.person-mask {
  position: fixed;
  inset: 0;
  z-index: 150;
  display: flex;
  align-items: flex-end;
  background: rgba(0, 0, 0, 0.35);
}

.project-mask {
  position: fixed;
  inset: 0;
  z-index: 145;
  display: flex;
  align-items: flex-end;
  background: rgba(0, 0, 0, 0.35);
}

.project-panel {
  width: 100%;
  max-height: 78vh;
  border-radius: 18rpx 18rpx 0 0;
  background: #ffffff;
  overflow: hidden;
}

.config-panel {
  max-height: 86vh;
}

.project-panel-body {
  max-height: calc(78vh - 92rpx);
  overflow-y: auto;
  padding: 24rpx 24rpx calc(80rpx + env(safe-area-inset-bottom));
}

.config-panel .project-panel-body {
  max-height: calc(86vh - 92rpx);
}

.config-mode-tabs {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
  margin-bottom: 22rpx;
  padding: 8rpx;
  border: 1rpx solid #d7e1de;
  border-radius: 10rpx;
  background: #ffffff;
}

.config-mode-tab {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 62rpx;
  border-radius: 8rpx;
  color: #52615d;
  font-size: 25rpx;
  font-weight: 900;
}

.config-mode-tab.active {
  color: #ffffff;
  background: #1f5f54;
}

.project-panel-body .field input {
  box-sizing: border-box;
  width: 100%;
  height: 76rpx;
  padding: 0 18rpx;
  border: 1rpx solid #d7e1de;
  border-radius: 8rpx;
  background: #ffffff;
  font-size: 26rpx;
}

.config-section-title button,
.config-equipment-card button {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 800;
  box-sizing: border-box;
}

.config-section-title button {
  color: #ffffff;
  background: #1f5f54;
}

.config-section-title,
.config-equipment-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin: 18rpx 0 14rpx;
  color: #17211e;
  font-size: 27rpx;
  font-weight: 900;
}

.config-section-title button {
  width: 136rpx;
  height: 58rpx;
}

.config-equipment-card {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 88rpx auto;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 16rpx;
  padding: 12rpx;
  border: 1rpx solid #d7e1de;
  border-radius: 8rpx;
  background: #fbfcfc;
}

.config-equipment-card input {
  height: 64rpx;
  min-width: 0;
  padding: 0 14rpx;
  border: 1rpx solid #d7e1de;
  border-radius: 8rpx;
  background: #ffffff;
  font-size: 25rpx;
}

.config-equipment-card button {
  width: 92rpx;
  height: 64rpx;
  border-radius: 8rpx;
  border: 1rpx solid #e0b4b4;
  color: #b42318;
  background: #fff7f7;
  font-size: 23rpx;
  font-weight: 800;
}

.equipment-qty-input {
  text-align: center;
}

.equipment-name-wrap {
  position: relative;
  min-width: 0;
}

.equipment-suggestions {
  position: absolute;
  right: 0;
  left: 0;
  top: 70rpx;
  z-index: 20;
  border: 1rpx solid #d7e1de;
  border-radius: 8rpx;
  background: #ffffff;
  overflow: hidden;
  box-shadow: 0 12rpx 28rpx rgba(23, 33, 30, 0.12);
}

.equipment-suggestion {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 12rpx;
  min-height: 64rpx;
  padding: 0 16rpx;
  border-bottom: 1rpx solid #edf2f0;
  color: #17211e;
  font-size: 24rpx;
  font-weight: 800;
}

.equipment-suggestion:last-child {
  border-bottom: 0;
}

.project-list {
  margin-top: 16rpx;
  border: 1rpx solid #d7e1de;
  border-radius: 8rpx;
  background: #ffffff;
  overflow: hidden;
}

.project-row-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 78rpx;
  padding: 0 22rpx;
  border-bottom: 1rpx solid #edf2f0;
  color: #17211e;
  font-size: 26rpx;
  font-weight: 800;
}

.project-row-item:last-child {
  border-bottom: 0;
}

.project-row-item.checked {
  color: #1f5f54;
  background: #edf7f4;
}

.person-panel {
  width: 100%;
  max-height: 78vh;
  border-radius: 18rpx 18rpx 0 0;
  background: #ffffff;
  overflow: hidden;
}

.person-panel-body {
  max-height: calc(78vh - 92rpx);
  overflow-y: auto;
  padding: 24rpx;
}

.person-search {
  width: 100%;
  height: 78rpx;
  padding: 0 20rpx;
  border: 1rpx solid #d7e1de;
  border-radius: 8rpx;
  background: #fbfcfc;
  color: #17211e;
  font-size: 27rpx;
  line-height: 78rpx;
}

.selected-line {
  margin-top: 14rpx;
  color: #1f5f54;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.45;
}

.person-list {
  margin-top: 16rpx;
  border: 1rpx solid #d7e1de;
  border-radius: 8rpx;
  background: #ffffff;
  overflow: hidden;
}

.person-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 76rpx;
  padding: 0 22rpx;
  border-bottom: 1rpx solid #edf2f0;
  color: #17211e;
  font-size: 27rpx;
  font-weight: 800;
}

.person-row:last-child {
  border-bottom: 0;
}

.person-row.checked {
  color: #1f5f54;
  background: #edf7f4;
}

.person-info {
  display: grid;
  gap: 6rpx;
  min-width: 0;
}

.person-check {
  width: 36rpx;
  color: #1f5f54;
  text-align: right;
  font-size: 28rpx;
  font-weight: 900;
}

.calendar-mask {
  position: fixed;
  inset: 0;
  z-index: 150;
  display: flex;
  align-items: flex-end;
  background: rgba(0, 0, 0, 0.35);
}

.calendar-panel {
  width: 100%;
  border-radius: 18rpx 18rpx 0 0;
  background: #ffffff;
  overflow: hidden;
}

.calendar-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 96rpx;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #edf2f0;
}

.calendar-title {
  color: #17211e;
  text-align: center;
  font-size: 29rpx;
  font-weight: 900;
}

.calendar-range-text {
  margin-top: 6rpx;
  color: #66726e;
  text-align: center;
  font-size: 22rpx;
  font-weight: 700;
}

.calendar-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 82rpx;
  padding: 0 24rpx;
}

.calendar-nav-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 60rpx;
  border-radius: 8rpx;
  color: #1f5f54;
  background: #edf7f4;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 60rpx;
}

.calendar-month {
  color: #17211e;
  font-size: 30rpx;
  font-weight: 900;
}

.calendar-weekdays,
.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
}

.calendar-weekdays {
  padding: 0 18rpx;
  color: #7c8884;
  text-align: center;
  font-size: 22rpx;
  font-weight: 800;
}

.calendar-grid {
  padding: 14rpx 18rpx 28rpx;
}

.calendar-day {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 76rpx;
  color: #17211e;
  font-size: 27rpx;
  font-weight: 800;
}

.calendar-day text {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
}

.calendar-day.muted {
  color: #b8c1bd;
}

.calendar-day.in-range {
  background: #edf7f4;
}

.calendar-day.selected-start text,
.calendar-day.selected-end text {
  color: #ffffff;
  background: #1f5f54;
}

.work-form textarea {
  min-height: 150rpx;
  padding: 18rpx 20rpx;
  line-height: 1.5;
}

