.task-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 900;
}

.page-subtitle {
  margin-top: 8rpx;
  color: #6b7773;
  font-size: 26rpx;
}

.add-button {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  color: #ffffff;
  background: #1f5f54;
  font-size: 42rpx;
  font-weight: 400;
  line-height: 68rpx;
}

.task-card {
  padding: 26rpx;
}

.task-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.task-title {
  flex: 1;
  min-width: 0;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.35;
}

.task-meta {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 18rpx;
  color: #6b7773;
  font-size: 24rpx;
}

.progress {
  height: 16rpx;
  margin-top: 24rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #e7eeeb;
}

.progress-bar {
  height: 100%;
  border-radius: 999rpx;
  background: #1f5f54;
}

.task-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 22rpx;
}

.priority {
  color: #40504b;
  font-size: 25rpx;
}

.mini-button {
  min-width: 112rpx;
  height: 56rpx;
  border: 1rpx solid #b9c9c4;
  border-radius: 999rpx;
  color: #1f5f54;
  background: #ffffff;
  font-size: 25rpx;
  line-height: 56rpx;
}
