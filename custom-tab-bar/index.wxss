.tab-shell {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 60;
  padding: 10rpx 28rpx calc(14rpx + env(safe-area-inset-bottom));
  background: transparent;
}

.tab-bar {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  align-items: center;
  min-height: 104rpx;
  padding: 10rpx 12rpx;
  border: 1rpx solid rgba(207, 218, 214, 0.9);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 12rpx 34rpx rgba(24, 54, 47, 0.13);
}

.tab-item {
  display: grid;
  justify-items: center;
  align-content: center;
  gap: 5rpx;
  min-width: 0;
  min-height: 84rpx;
  border-radius: 16rpx;
  color: #66726e;
}

.tab-item.active {
  color: #1f5f54;
  background: #e8f4f1;
}

.tab-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38rpx;
  height: 34rpx;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1;
}

.tab-text {
  max-width: 100%;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.2;
  white-space: nowrap;
}
